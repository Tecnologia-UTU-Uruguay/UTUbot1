tiempo = 0
distancia = 0

def medir_distancia():
    global tiempo, distancia
    
    # Reiniciar variables
    tiempo = 0
    distancia = 0
    
    # Enviar pulso de trigger
    pins.digital_write_pin(DigitalPin.P13, 0)
    control.wait_micros(2)
    pins.digital_write_pin(DigitalPin.P13, 1)
    control.wait_micros(10)
    pins.digital_write_pin(DigitalPin.P13, 0)
    
    # Medir el tiempo de eco
    tiempo = pins.pulse_in(DigitalPin.P12, PulseValue.HIGH, 30000)  # timeout de 30ms
    
    # Calcular distancia (en cm)
    if tiempo > 0:
        distancia = tiempo / 58
    else:
        distancia = 999  # Valor alto si no detecta nada
    
    return distancia

def on_forever():
    dist = medir_distancia()
    basic.pause(50)  # Pequeña pausa entre mediciones
    
    if dist <= 10 and dist > 0:
        # Secuencia de evasión de obstáculos
        # 1. Retroceder
        robotbit.motor_run(robotbit.Motors.M1A, -175)
        robotbit.motor_run(robotbit.Motors.M1B, 175)
        basic.pause(500)
        
        # 2. Girar a la derecha
        robotbit.motor_run(robotbit.Motors.M1A, -175)
        robotbit.motor_run(robotbit.Motors.M1B, -175)
        basic.pause(400)
        
        # 3. Avanzar para esquivar
        robotbit.motor_run(robotbit.Motors.M1A, 175)
        robotbit.motor_run(robotbit.Motors.M1B, -175)
        basic.pause(1000)
        
        # 4. Girar a la izquierda para reorientarse
        robotbit.motor_run(robotbit.Motors.M1A, 175)
        robotbit.motor_run(robotbit.Motors.M1B, 175)
        basic.pause(400)
        
        # 5. Avanzar un poco más
        robotbit.motor_run(robotbit.Motors.M1A, 175)
        robotbit.motor_run(robotbit.Motors.M1B, -175)
        basic.pause(500)
        
    else:
        # Avanzar normalmente
        robotbit.motor_run(robotbit.Motors.M1A, 255)
        robotbit.motor_run(robotbit.Motors.M1B, -255)

basic.forever(on_forever)
